# Enterprise Agentic Platform - Environment Configuration
# Copy this file to .env and customize for your deployment
# 
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker-compose up --build

# ===========================================
# REQUIRED: API Configuration
# ===========================================
# Your Google API key for Gemini models
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSyAKzR9AUSyPX5EQW1i8obQjSfFVpewV8A0

# ===========================================
# OPTIONAL: Model Configuration
# ===========================================
# Gemini model to use (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.0-pro, gemini-1.5-pro
MODEL_NAME=gemini-2.5-flash

# ===========================================
# OPTIONAL: Branding Configuration
# ===========================================
# Customize these for your company/team

# Company/Team name displayed in the UI
COMPANY_NAME="Agent Platform"

# Project name shown in header
PROJECT_NAME="Enterprise Agentic Platform"

# Primary brand color (hex) - Used for buttons, headers
PRIMARY_COLOR="#0066B3"

# Secondary brand color (hex) - Used for gradients
SECONDARY_COLOR="#1E3A8A"

# Accent color (hex) - Used for highlights
ACCENT_COLOR="#0EA5E9"

# Mascot character name
MASCOT_NAME="Marina"

# ===========================================
# OPTIONAL: Server Configuration
# ===========================================
# Port to expose (default: 8000)
PORT=8000

# ===========================================
# OPTIONAL: Skills Configuration
# ===========================================
# Directory containing skill markdown files
SKILLS_DIR=".skills"

# ===========================================
# OPTIONAL: Debug Mode
# ===========================================
# Enable debug mode (true/false)
DEBUG=false
